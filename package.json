{
  "name": "ceviz",
  "displayName": "CEVIZ",
  "description": "Local Personal Hybrid AI",
  "version": "0.2.0",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ceviz-sidebar",
          "title": "CEVIZ",
          "icon": "media/walnut.svg"
        }
      ]
    },
    "views": {
      "ceviz-sidebar": [
        {
          "type": "webview",
          "id": "ceviz.chatView",
          "name": "My AI Creations"
        }
      ]
    },
    "commands": [
      { "command": "ceviz.newSession", "title": "CEVIZ: New Session" },
      { "command": "ceviz.toggleEnglish", "title": "CEVIZ: Toggle English Mode" },
      { "command": "ceviz.openDashboard", "title": "CEVIZ: Open Soti-Skill Dashboard" }
    ],
    "configuration": {
      "title": "CEVIZ",
      "properties": {
        "ceviz.serverIp": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "PN40 서버 Tailscale IP"
        },
        "ceviz.defaultCloudModel": {
          "type": "string",
          "default": "claude",
          "description": "Hybrid 모드 기본 Cloud AI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.0.0"
  }
}
